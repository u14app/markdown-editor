{
  "name": "@xiangfa/mdeditor",
  "description": "A Markdown editor with built-in syntax highlighting based on CodeMirror.",
  "version": "0.3.8",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/u14app/markdown-editor.git"
  },
  "keywords": [
    "markdown",
    "markdown editor",
    "editor"
  ],
  "sideEffects": false,
  "main": "./dist/editor/index.js",
  "module": "./dist/editor/index.js",
  "types": "./dist/editor/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor/index.js",
      "default": "./dist/editor/index.js"
    },
    "./commands": {
      "types": "./dist/editor/commands/index.d.ts",
      "import": "./dist/editor/commands/index.js"
    },
    "./icons": {
      "types": "./dist/editor/icons/index.d.ts",
      "import": "./dist/editor/icons/index.js"
    },
    "./ai": {
      "types": "./dist/editor/plugins/ai/index.d.ts",
      "import": "./dist/editor/plugins/ai/index.js"
    },
    "./theme": {
      "types": "./dist/editor/theme.d.ts",
      "import": "./dist/editor/theme.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "vite",
    "tsc": "tsc --noEmit",
    "build": "rimraf './dist' && vite build",
    "test": "vitest"
  },
  "peerDependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "lucide": "^0.577.0"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@lezer/highlight": "^1.2.3",
    "@types/node": "^22.19.15",
    "codemirror": "^6.0.2",
    "glob": "^13.0.6",
    "lucide": "^0.577.0",
    "rimraf": "^6.1.3",
    "typescript": "~5.7.3",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
